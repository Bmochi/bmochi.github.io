# ── Microsoft Azure App Registration ─────────────────────────────────────────
# Create an App Registration in Azure Portal → Azure Active Directory
# Grant it: Sites.Read.All + Files.Read.All (Application permissions) on Graph API

TENANT_ID=your-azure-tenant-id
CLIENT_ID=your-azure-app-client-id
CLIENT_SECRET=your-azure-app-client-secret

# ── SharePoint / Excel File ───────────────────────────────────────────────────
# How to find these values — run the helper commands in SETUP.md, or:
#
# SHAREPOINT_DRIVE_ID:
#   GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
#   Use the "id" of the drive that contains your Excel file.
#
# EXCEL_FILE_ID:
#   GET https://graph.microsoft.com/v1.0/drives/{drive-id}/root/children
#   Find your .xlsx file and copy its "id".

SHAREPOINT_DRIVE_ID=your-drive-id
EXCEL_FILE_ID=your-excel-file-item-id
EXCEL_SHEET_NAME=Sheet1

# Row number (1-based) that contains column headers. Default is 1.
EXCEL_HEADER_ROW=1

# ── Slack ─────────────────────────────────────────────────────────────────────
# In Slack: Apps → Incoming Webhooks → Add to a channel → copy the URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── State file (optional) ─────────────────────────────────────────────────────
# Path to the JSON file that tracks how many rows have been processed.
# Defaults to ./state.json next to index.js.
# STATE_FILE=./state.json
